{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Shop Apotheke driver — HTML + JSON-LD, brand/GTIN may be missing",
  "type": "object",
  "required": ["name", "images", "warnings"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "gtin": { "type": "string", "pattern": "^\\d{8,13}$" },
    "brandName": { "type": "string", "minLength": 1 },
    "priceCents": { "type": "integer", "minimum": 10, "maximum": 100000 },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
